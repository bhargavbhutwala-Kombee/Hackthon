{
  "uid": "system-metrics",
  "title": "System Overview (Backend + Frontend Metrics)",
  "tags": ["prometheus", "metrics"],
  "schemaVersion": 36,
  "refresh": "10s",
  "time": {"from": "now-30m", "to": "now"},
  "panels": [
    {
      "id": 1,
      "title": "🔧 Backend — HTTP Requests Per Second",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 7},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {
          "expr": "sum by(method, uri) (rate(http_server_requests_seconds_count{job=\"orderly-backend\"}[1m]))",
          "legendFormat": "{{method}} {{uri}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "🌐 Frontend — Nginx Active Connections",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 7},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {
          "expr": "nginx_connections_active{job=\"nginx-frontend\"}",
          "legendFormat": "Active Connections"
        },
        {
          "expr": "nginx_connections_waiting{job=\"nginx-frontend\"}",
          "legendFormat": "Waiting"
        },
        {
          "expr": "nginx_connections_reading{job=\"nginx-frontend\"}",
          "legendFormat": "Reading"
        }
      ]
    },
    {
      "id": 3,
      "title": "⏱️ Backend — p95 Request Latency by Endpoint",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 7, "w": 12, "h": 7},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by(le, uri) (rate(http_server_requests_seconds_bucket{job=\"orderly-backend\"}[2m])))",
          "legendFormat": "p95 {{uri}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "🌐 Frontend — Total Nginx Requests (Handled vs Accepted)",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 7, "w": 12, "h": 7},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {
          "expr": "rate(nginx_http_requests_total{job=\"nginx-frontend\"}[1m])",
          "legendFormat": "Requests/s"
        }
      ]
    },
    {
      "id": 5,
      "title": "❌ Backend — HTTP Error Rate %",
      "type": "gauge",
      "gridPos": {"x": 0, "y": 14, "w": 6, "h": 6},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {"steps": [{"color": "green","value": 0},{"color": "yellow","value": 0.05},{"color": "red","value": 0.1}]}
        }
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{job=\"orderly-backend\",status=~\"5..\"}[2m])) / sum(rate(http_server_requests_seconds_count{job=\"orderly-backend\"}[2m]))",
          "legendFormat": "Error Rate"
        }
      ]
    },
    {
      "id": 6,
      "title": "🗄️ Backend — DB Connection Pool (HikariCP)",
      "type": "timeseries",
      "gridPos": {"x": 6, "y": 14, "w": 9, "h": 6},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {
          "expr": "hikaricp_connections_active{job=\"orderly-backend\"}",
          "legendFormat": "Active"
        },
        {
          "expr": "hikaricp_connections_idle{job=\"orderly-backend\"}",
          "legendFormat": "Idle"
        },
        {
          "expr": "hikaricp_connections_max{job=\"orderly-backend\"}",
          "legendFormat": "Max"
        }
      ]
    },
    {
      "id": 7,
      "title": "💾 Backend JVM Memory Used",
      "type": "timeseries",
      "gridPos": {"x": 15, "y": 14, "w": 9, "h": 6},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "bytes"}},
      "targets": [
        {
          "expr": "sum by(area) (jvm_memory_used_bytes{job=\"orderly-backend\"})",
          "legendFormat": "{{area}}"
        }
      ]
    }
  ],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0
      }
    ]
  }
}
